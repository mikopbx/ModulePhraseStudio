parameters:
    level: 0
    paths:
        - Lib
        - Models
        - App
        - Setup
    scanDirectories:
        - ../../Core/src
    parallel:
        jobSize: 20
        processTimeout: 300.0
    tmpDir: /tmp/phpstan-ModulePhraseStudio
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        -
            # Globals.php is resolved at runtime via the include_path set in
            # /etc/php.d/50-mikopbx.ini (.:/usr/www/src/Core/Config). PHPStan
            # has no way of knowing that — silence the static-analysis noise.
            message: '#Path in require_once\(\) "Globals\.php" is not a file or it does not exist#'
        -
            message: '#unknown class Phalcon\\Di#'
        -
            message: '#Class Phalcon\\Validation not found#'
        -
            message: '#Class Phalcon\\Validation\\Validator\\Uniqueness not found#'
        -
            message: '#Class Phalcon\\Text not found#'
        -
            message: '#Class Phalcon\\Logger not found#'
